{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npx markdownlint-cli*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Validating plugin structure...",
            "command": "claude plugin validate \"$CLAUDE_PROJECT_DIR\""
          },
          {
            "type": "command",
            "if": "Write(*.md)|Edit(*.md)",
            "statusMessage": "Linting markdown...",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx markdownlint-cli \"**/*.md\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Validating plugin structure...",
            "command": "claude plugin validate \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ]
  }
}
